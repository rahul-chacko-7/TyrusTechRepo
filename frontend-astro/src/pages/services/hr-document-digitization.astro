---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
const pageTitle = 'HR Document Digitization Services | Tyrus Technologies';
---

<DefaultLayout>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
        Services · HR Documents
      </p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900">
        HR document digitization for faster people operations.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        We scan and organize employee files, onboarding packs and compliance records so your HR and
        payroll teams can access information quickly without digging through cupboards and cartons.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-[1.2fr,1fr]">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Typical HR records we digitize.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Employee personal files and service records.</li>
          <li>• Joining and exit documents.</li>
          <li>• Appraisal and performance records.</li>
          <li>• Training, compliance and policy acknowledgements.</li>
        </ul>
      </div>
      <div class="space-y-4 rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Smart organization</h3>
        <ul class="mt-2 space-y-2 text-sm text-slate-800">
          <li>• Indexing by employee ID, department and location.</li>
          <li>• Clear folder structures for active and inactive employees.</li>
          <li>• Easy export of specific files for audits or investigations.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-2">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold text-slate-900">Benefits for HR and management.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Quick access to employee files during reviews and discussions.</li>
          <li>• Faster response to labour, legal and compliance queries.</li>
          <li>• Reduced risk of lost or incomplete employee records.</li>
        </ul>
      </div>
      <div class="space-y-3 rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Flexible engagement models</h3>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• One‑time backlog digitization of legacy records.</li>
          <li>• Ongoing digitization of new employee documents.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-xl font-semibold text-slate-900">
          Make HR files easy to find and secure.
        </h2>
        <p class="mt-2 text-sm text-slate-700">
          Share your employee count, number of years of records and locations. We will suggest a
          practical HR digitization plan with clear timelines and budgets.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="/#cost-calculator"
            class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Get a free estimate
          </a>
          <a
            href="/contact"
            class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
          >
            Talk to our HR solutions team
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

