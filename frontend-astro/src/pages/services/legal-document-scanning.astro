---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
const pageTitle = 'Legal Document Scanning Services | Tyrus Technologies';
---

<DefaultLayout
  title={pageTitle}
  description="Legal document scanning for law firms and legal teams in India. We digitize case files, contracts and evidence bundles with confidentiality and easy access."
>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
        Services · Legal Documents
      </p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900">
        Legal document scanning for law firms and legal teams.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        We digitize case files, contracts and evidence bundles so your lawyers and legal teams can
        search, share and present documents faster while protecting confidentiality.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-[1.2fr,1fr]">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Types of legal records we scan.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Case files and pleadings.</li>
          <li>• Contracts, agreements and addendums.</li>
          <li>• Evidence bundles, annexures and exhibits.</li>
          <li>• Board minutes and corporate secretarial records.</li>
        </ul>
      </div>
      <div class="space-y-4 rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Confidentiality by design</h3>
        <ul class="mt-2 space-y-2 text-sm text-slate-800">
          <li>• NDAs and background‑verified staff.</li>
          <li>• Restricted access areas for sensitive matters.</li>
          <li>• Clear chain‑of‑custody for physical and digital records.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-2">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold text-slate-900">Making legal work easier.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Matter‑wise folder structures aligned to your practice areas.</li>
          <li>• File naming that makes sense to lawyers and support staff.</li>
          <li>• Quick search by party name, matter ID, court or date.</li>
          <li>• Easy sharing of sets for counsel and client reviews.</li>
        </ul>
      </div>
      <div class="space-y-3 rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Outcomes</h3>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Faster preparation for hearings and filings.</li>
          <li>• Less time spent searching through cartons and cupboards.</li>
          <li>• Better control over who can see which matter files.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-xl font-semibold text-slate-900">
          Digitize your legal archives in a structured way.
        </h2>
        <p class="mt-2 text-sm text-slate-700">
          Whether you are a law firm or an in‑house legal team, we can help you design a scanning and
          indexing approach that works with how your matters are organized today.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="/contact"
            class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Talk to our legal team
          </a>
          <a
            href="/#cost-calculator"
            class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
          >
            Get an estimate
          </a>
        </div>
      </div>
    </div>
  </section>
  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 pb-12">
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <h2 class="text-lg font-semibold text-slate-900">Explore more services</h2>
        <p class="mt-2 text-sm text-slate-700">Compare related solutions to build the right digitization workflow for your organization.</p>
        <div class="mt-4 flex flex-wrap gap-3 text-sm">
          <a href="/services" class="rounded-full border border-emerald-300 px-4 py-1.5 font-medium text-emerald-700 hover:bg-emerald-50">All services</a>
          <a href="/industries" class="rounded-full border border-slate-300 px-4 py-1.5 font-medium text-slate-700 hover:bg-slate-100">Industries</a>
          <a href="/blog" class="rounded-full border border-slate-300 px-4 py-1.5 font-medium text-slate-700 hover:bg-slate-100">Read guides</a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>


