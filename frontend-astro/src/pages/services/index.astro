---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
const pageTitle = 'Document Digitization & Scanning Services | Tyrus Technologies';
---

<DefaultLayout
  title={pageTitle}
  description="Explore document digitization, document scanning, OCR data capture, digital archives and specialised services from Tyrus Technologies."
>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <h1 class="text-3xl font-semibold text-slate-900">
        Document digitization & scanning services.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        Tyrus Technologies provides end‑to‑end services to move your organization from paper‑heavy processes
        to secure, searchable digital records. Choose a single service or combine them into a complete
        digitization program.
      </p>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto grid max-w-6xl gap-5 px-4 py-12 md:grid-cols-2 lg:grid-cols-3">
      <a href="/services/document-scanning" class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 hover:ring-emerald-300">
        <h2 class="text-sm font-semibold text-slate-900">Document Scanning Services</h2>
        <p class="mt-2 text-xs text-slate-700">
          High‑speed scanning of loose sheets and files with quality checks, indexing and secure handling.
        </p>
      </a>
      <a href="/services/document-digitization" class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 hover:ring-emerald-300">
        <h2 class="text-sm font-semibold text-slate-900">Document Digitization</h2>
        <p class="mt-2 text-xs text-slate-700">
          End‑to‑end projects to convert large physical archives into structured, digital repositories.
        </p>
      </a>
      <a href="/services/data-capture-ocr" class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 hover:ring-emerald-300">
        <h2 class="text-sm font-semibold text-slate-900">Data Capture &amp; OCR</h2>
        <p class="mt-2 text-xs text-slate-700">
          Extract key fields from scanned images using OCR and manual verification for high accuracy.
        </p>
      </a>
      <a href="/services/digital-archives" class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 hover:ring-emerald-300">
        <h2 class="text-sm font-semibold text-slate-900">Digital Archives</h2>
        <p class="mt-2 text-xs text-slate-700">
          Organize and store documents in searchable digital archives with role‑based access and retention.
        </p>
      </a>
      <a href="/services/medical-record-scanning" class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 hover:ring-emerald-300">
        <h2 class="text-sm font-semibold text-slate-900">Medical Record Scanning</h2>
        <p class="mt-2 text-xs text-slate-700">
          OPD / IPD files, MRD archives and diagnostic reports digitized for faster clinical and admin access.
        </p>
      </a>
      <a href="/services/legal-document-scanning" class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 hover:ring-emerald-300">
        <h2 class="text-sm font-semibold text-slate-900">Legal Document Scanning</h2>
        <p class="mt-2 text-xs text-slate-700">
          Case files, contracts and evidence bundles scanned and bundled for quick, secure reference.
        </p>
      </a>
      <a href="/services/hr-document-digitization" class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 hover:ring-emerald-300">
        <h2 class="text-sm font-semibold text-slate-900">HR Document Digitization</h2>
        <p class="mt-2 text-xs text-slate-700">
          Employee files, onboarding documents and compliance records digitized for faster HR operations.
        </p>
      </a>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-xl font-semibold text-slate-900">
          Not sure where to start?
        </h2>
        <p class="mt-2 text-sm text-slate-700">
          Share a rough idea of your page volumes and document types. Our team will suggest a practical
          digitization plan and cost range for your organization.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="/#cost-calculator"
            class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Get a free estimate
          </a>
          <a
            href="/contact"
            class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
          >
            Talk to a specialist
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

