---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
const pageTitle = 'Medical Record Scanning Services | Tyrus Technologies';
---

<DefaultLayout>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
        Services · Medical Records
      </p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900">
        Medical record scanning for hospitals and clinics.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        We help MRD and medical records teams digitize OPD / IPD files, case sheets and reports so
        doctors and administrators can retrieve records in seconds while reducing pressure on record rooms.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-[1.2fr,1fr]">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">What we handle.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• OPD and IPD case files and continuation sheets.</li>
          <li>• Consent forms, operative notes and discharge summaries.</li>
          <li>• Investigation reports, radiology reports and lab documents.</li>
          <li>• Legacy MRD archives stored in cartons and bundles.</li>
        </ul>
      </div>
      <div class="space-y-4 rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Designed for healthcare operations</h3>
        <ul class="mt-2 space-y-2 text-sm text-slate-800">
          <li>• Indexing by MRN, patient name, episode or visit number.</li>
          <li>• Batch‑wise tracking for medico‑legal and audit needs.</li>
          <li>• Configurable retention and weeding rules.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-2">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold text-slate-900">How the MRD scanning process works.</h2>
        <ol class="list-decimal space-y-2 pl-5 text-sm text-slate-800">
          <li>We study your MRD workflows and legal / regulatory needs.</li>
          <li>We define batches (by year, specialty, location or store room).</li>
          <li>We scan on‑site inside secure hospital premises, or at a secure facility.</li>
          <li>We index and verify records with your MRD team.</li>
          <li>We deliver scanned records in a format that connects to EMR or DMS.</li>
        </ol>
      </div>
      <div class="space-y-3 rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Benefits for your hospital</h3>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Faster retrieval for medico‑legal, insurance and clinical needs.</li>
          <li>• Reduced record room space and carton storage.</li>
          <li>• Better compliance with retention and access policies.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-xl font-semibold text-slate-900">
          Plan your medical record digitization project.
        </h2>
        <p class="mt-2 text-sm text-slate-700">
          Share your approximate file volumes and store room details. We will propose a phased plan
          that fits your MRD capacity and budget.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="/#cost-calculator"
            class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Get a free estimate
          </a>
          <a
            href="/contact"
            class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
          >
            Talk to our healthcare team
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

