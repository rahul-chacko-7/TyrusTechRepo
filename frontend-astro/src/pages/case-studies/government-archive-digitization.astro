---
import DefaultLayout from '../../layouts/DefaultLayout.astro';

const pageTitle = 'Government Archive Digitization Case Study | Tyrus Technologies';
const pageDescription =
  'Government record digitization case study for department archives, land records, citizen files, registers, OCR indexing, and traceable digital handover.';
---

<DefaultLayout title={pageTitle} description={pageDescription}>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700">Government Case Study</p>
      <h1 class="mt-2 max-w-4xl text-3xl font-semibold text-slate-900">
        Government archive and citizen record digitization for faster public service response.
      </h1>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-700">
        Department archives, registers, citizen files, land records, and legacy paper bundles need
        careful handling because they are frequently old, sensitive, and important for public
        service, RTI, audit, and legal reference.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 md:grid-cols-2">
      <div class="rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h2 class="text-lg font-semibold text-slate-900">Records digitized</h2>
        <ul class="mt-3 space-y-2 text-sm text-slate-700">
          <li>Land and citizen service records</li>
          <li>Legacy registers and bound volumes</li>
          <li>Department files and archive cartons</li>
          <li>Index sheets, metadata, and search-ready folders</li>
        </ul>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-slate-900">Digitization approach</h2>
        <p class="mt-3 text-sm leading-7 text-slate-700">
          The project required document preparation, secure movement, scanning suited to the
          condition of old papers, OCR where appropriate, and indexing that helped departments
          identify records by category, year, citizen reference, file number, or register details.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-xl font-semibold text-slate-900">Outcomes</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {[
          ['Faster traceability', 'Staff could locate records by index fields instead of physically searching old bundles.'],
          ['Lower handling risk', 'Original records were handled less often after digital copies became available.'],
          ['Better citizen service', 'Department teams had a clearer path for RTI, service, audit, and reference requests.']
        ].map(([title, text]) => (
          <article class="rounded-2xl bg-slate-50 p-5 ring-1 ring-slate-200">
            <h3 class="text-sm font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-xs leading-6 text-slate-700">{text}</p>
          </article>
        ))}
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/government-record-digitization-services" class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white hover:bg-emerald-700">Government record digitization</a>
        <a href="/posts/government-archive-digitization-checklist" class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50">Government digitization checklist</a>
      </div>
    </div>
  </section>
</DefaultLayout>
