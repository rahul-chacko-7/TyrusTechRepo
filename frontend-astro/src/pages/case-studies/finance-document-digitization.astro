---
import DefaultLayout from '../../layouts/DefaultLayout.astro';

const pageTitle = 'Finance Document Digitization Case Study | Tyrus Technologies';
const pageDescription =
  'Finance document digitization case study showing how invoice, approval, and audit records can be scanned, OCR indexed, and retrieved faster with Tyrus Technologies.';

const metrics = [
  ['Document type', 'Invoices, approvals, vouchers, supporting finance records'],
  ['Primary need', 'Faster invoice processing, payment follow-up, and audit retrieval'],
  ['Output', 'Searchable PDFs, indexed folders, metadata sheets, and controlled handover'],
  ['Services used', 'Document scanning, OCR indexing, quality checks, digital archive output']
];

const pageSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: pageTitle,
    description: pageDescription,
    author: {
      '@type': 'Organization',
      name: 'Tyrus Technologies Pvt Ltd'
    },
    publisher: {
      '@type': 'Organization',
      name: 'Tyrus Technologies Pvt Ltd',
      logo: {
        '@type': 'ImageObject',
        url: 'https://www.tyrustech.com/favicon.svg'
      }
    },
    mainEntityOfPage: 'https://www.tyrustech.com/case-studies/finance-document-digitization'
  }
];
---

<DefaultLayout title={pageTitle} description={pageDescription} schemas={pageSchemas}>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">
        Finance Case Study
      </p>
      <h1 class="mt-2 max-w-4xl text-3xl font-semibold text-slate-900">
        Finance document digitization for faster invoice processing and audit retrieval.
      </h1>
      <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-700">
        This case study explains a practical finance digitization workflow: scanning finance
        records, creating searchable files, and making invoice support documents easier to find for
        approval, vendor, and audit teams.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 md:grid-cols-[1fr,1.1fr]">
      <div class="rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h2 class="text-lg font-semibold text-slate-900">Project snapshot</h2>
        <dl class="mt-5 space-y-4">
          {metrics.map(([label, value]) => (
            <div>
              <dt class="text-xs font-semibold uppercase tracking-wide text-slate-500">{label}</dt>
              <dd class="mt-1 text-sm leading-6 text-slate-800">{value}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div>
        <h2 class="text-xl font-semibold text-slate-900">The challenge</h2>
        <p class="mt-3 text-sm leading-7 text-slate-700">
          Finance teams often need to locate invoices, approvals, vouchers, tax documents, and
          supporting papers during payment cycles, vendor queries, and audits. When those documents
          are stored in files or cartons, approval delays and repeated manual searching become a
          daily cost.
        </p>
        <h2 class="mt-8 text-xl font-semibold text-slate-900">The Tyrus workflow</h2>
        <ol class="mt-3 list-decimal space-y-2 pl-5 text-sm leading-7 text-slate-700">
          <li>Review finance record categories, approval stages, and search fields.</li>
          <li>Batch invoices and supporting records by year, vendor, department, or voucher type.</li>
          <li>Scan files with image quality checks and page-level exception handling.</li>
          <li>Apply OCR and index records using fields that finance and audit teams actually search.</li>
          <li>Deliver searchable PDFs, structured folders, and metadata sheets for archive handover.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-xl font-semibold text-slate-900">Business outcomes</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {[
          ['Faster invoice lookup', 'Teams can search by vendor, invoice number, date, or department instead of opening physical files.'],
          ['Better audit readiness', 'Finance records are organized for internal audit, statutory audit, and compliance review.'],
          ['Lower handling effort', 'Repeated movement of old finance files reduces once digital records are available.']
        ].map(([title, text]) => (
          <article class="rounded-2xl bg-slate-50 p-5 ring-1 ring-slate-200">
            <h3 class="text-sm font-semibold text-slate-900">{title}</h3>
            <p class="mt-2 text-xs leading-6 text-slate-700">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <h2 class="text-xl font-semibold text-slate-900">Related services</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        {[
          ['Document digitization services', '/document-digitization-services'],
          ['OCR indexing services', '/ocr-indexing-services'],
          ['Document scanning cost guide', '/posts/document-digitization-services-price-cost-india']
        ].map(([label, href]) => (
          <a href={href} class="rounded-2xl bg-white p-5 text-sm font-semibold text-slate-900 ring-1 ring-slate-200 hover:text-emerald-700 hover:ring-emerald-300">{label}</a>
        ))}
      </div>
    </div>
  </section>
</DefaultLayout>
