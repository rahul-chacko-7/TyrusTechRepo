---
import DefaultLayout from '../layouts/DefaultLayout.astro';
const pageTitle = 'Contact Tyrus Technologies | Document Digitization Services';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<DefaultLayout>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
        Contact
      </p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900">
        Contact Tyrus Technologies.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        Share a few details about your digitization needs. Our team will get in touch to understand
        your records, locations and timelines, and suggest a practical next step.
      </p>
    </div>
  </section>

        <div class="space-y-4 rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h2 class="text-sm font-semibold text-slate-900">Tell us about your project.</h2>
        <form
          id="contact-form"
          class="mt-3 space-y-3 text-sm"
        >
          <div class="grid gap-3 md:grid-cols-2">
            <div>
              <label for="name" class="mb-1 block text-xs font-medium text-slate-700">Name</label>
              <input
                id="name"
                name="name"
                required
                class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                placeholder="Your full name"
              />
            </div>
            <div>
              <label for="company" class="mb-1 block text-xs font-medium text-slate-700">Organization</label>
              <input
                id="company"
                name="company"
                class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                placeholder="Hospital, bank, company, etc."
              />
            </div>
            <div>
              <label for="email" class="mb-1 block text-xs font-medium text-slate-700">Work email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                placeholder="you@company.com"
              />
            </div>
            <div>
              <label for="phone" class="mb-1 block text-xs font-medium text-slate-700">Phone</label>
              <input
                id="phone"
                name="phone"
                class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                placeholder="+91 ..."
              />
            </div>
            <div>
              <label for="city" class="mb-1 block text-xs font-medium text-slate-700">City</label>
              <input
                id="city"
                name="city"
                class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                placeholder="Project location"
              />
            </div>
            <div>
              <label for="pages" class="mb-1 block text-xs font-medium text-slate-700">Approx. number of pages</label>
              <input
                id="pages"
                name="pages"
                type="number"
                min="0"
                class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
                placeholder="If known"
              />
            </div>
          </div>
          <div>
            <label for="message" class="mb-1 block text-xs font-medium text-slate-700">Brief description</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-200"
              placeholder="Example: We want to digitize 5 years of medical records across 2 locations."
            ></textarea>
          </div>
          <p id="contact-error" class="text-xs text-rose-500"></p>
          <p id="contact-success" class="text-xs text-emerald-600"></p>
          <button
            type="submit"
            class="mt-1 inline-flex items-center gap-2 rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Submit
          </button>
        </form>
      </div>
      </div>

      <div class="space-y-6">
        <div class="rounded-2xl bg-white p-6 ring-1 ring-slate-200">
          <h2 class="text-sm font-semibold text-slate-900">Other ways to reach us</h2>
          <dl class="mt-3 space-y-2 text-sm text-slate-800">
            <div>
              <dt class="font-medium">Email</dt>
              <dd>sales@tyrustech.com</dd>
            </div>
            <div>
              <dt class="font-medium">Phone</dt>
              <dd>+91 80898 89853</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>
   <script type="module" define:vars={{ supabaseUrl, supabaseAnonKey }}>
    import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.47.4/+esm';

    const supabaseClient = createClient(supabaseUrl, supabaseAnonKey);

    const form = document.getElementById('contact-form');
    const errorEl = document.getElementById('contact-error');
    const successEl = document.getElementById('contact-success');

    if (form) {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(form);
        const name = String(formData.get('name') || '');
        const company = String(formData.get('company') || '');
        const email = String(formData.get('email') || '');
        const phone = String(formData.get('phone') || '');
        const city = String(formData.get('city') || '');
        const pagesRaw = formData.get('pages');
        const pages = pagesRaw ? Number(pagesRaw) || 0 : 0;
        const estimatedPriceRaw = formData.get('estimated_price');
        const estimatedPrice = estimatedPriceRaw ? Number(estimatedPriceRaw) || 0 : 0;

        if (errorEl) errorEl.textContent = '';
        if (successEl) successEl.textContent = '';

        if (!name || !email) {
          if (errorEl) {
            errorEl.textContent = 'Name and work email are required.';
          }
          return;
        }

        try {
          const { error } = await supabaseClient.from('leads').insert([{
            name,
            company,
            email,
            phone,
            city,
            pages,
            estimated_price: estimatedPrice,
          }]);
          if (error) throw error;

          form.reset();
          if (successEl) {
            successEl.textContent =
              'Thank you! Our team will contact you shortly with a detailed quote.';
          }
        } catch (err) {
          if (errorEl) {
            errorEl.textContent =
              'Unable to submit right now. Please email or call us directly.';
          }
        }
      });
    }
  </script>
</DefaultLayout>

