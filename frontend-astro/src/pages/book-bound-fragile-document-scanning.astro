---
import SeoServicePage from '../components/SeoServicePage.astro';

const props = {
  title: 'Book, Bound & Fragile Document Scanning Services | Tyrus',
  description: 'Book scanning, bound register scanning and fragile document scanning services for old records, archives, registers, historical files and preservation-focused digitization.',
  canonical: '/book-bound-fragile-document-scanning',
  eyebrow: 'Bound and fragile records',
  h1: 'Book, bound and fragile document scanning services',
  serviceType: 'Book and Fragile Document Scanning Services',
  intro: 'Tyrus Technologies supports scanning for bound registers, old books, fragile records, historical files and archive documents that need careful handling, indexing and preservation-focused digital output.',
  primaryItems: [
    'Book scanning and bound register scanning for ledgers, minutes books, case registers, institutional records and old archive volumes.',
    'Fragile document scanning for aged, brittle, torn, folded or delicate paper records.',
    'Output planning for PDF, searchable PDF, PDF/A, TIFF or image archive formats.',
    'Indexing by book title, register number, year, department, page range, subject, location or record category.',
    'Exception reporting for damaged pages, missing pages, illegible content and preservation limitations.'
  ],
  outputs: [
    'Book-wise or register-wise PDF files',
    'PDF/A or TIFF archive output',
    'Searchable PDF where OCR is practical',
    'Excel or CSV metadata index',
    'Page sequence and exception reports',
    'Secure archive handover'
  ],
  process: [
    ['Assess condition', 'We review paper condition, binding, page sequence, fragility and scanning risk before production.'],
    ['Define handling', 'We agree on handling rules, page order, naming, metadata and output format.'],
    ['Scan carefully', 'Records are scanned with attention to page safety, sequence, legibility and image quality.'],
    ['Index and handover', 'Final files are named, indexed and delivered with exception notes for archive teams.']
  ],
  trustItems: [
    'Useful for institutions that need preservation-focused digitization rather than basic bulk scanning.',
    'Supports old registers, bound volumes and archive material where document condition affects process design.',
    'Can include onsite scanning for records that should remain inside the institution or archive room.'
  ],
  costFactors: [
    'Fragility, binding type, page condition, paper size and handling time.',
    'OCR practicality, page sequence checks, metadata fields and archive output format.',
    'Onsite requirement, volume count, page estimates and preservation rules.'
  ],
  relatedLinks: [
    ['Large format scanning', '/large-format-document-scanning-services', 'For drawings, maps, plans and oversized records.'],
    ['Document conversion services', '/document-conversion-services-india', 'For paper-to-digital conversion planning.'],
    ['Government record digitization', '/government-record-digitization-services', 'For public-sector records, registers and archives.'],
    ['PDF scanning services', '/pdf-scanning-services-india', 'For PDF, searchable PDF and PDF/A output.']
  ],
  industries: [
    'Government archives and departments',
    'Education institutions and universities',
    'Hospitals and legacy medical records',
    'Legal and court-related archives',
    'Manufacturing and facility record rooms',
    'Libraries, trusts and historical archives'
  ],
  faqs: [
    ['Can bound registers be scanned?', 'Yes. Bound registers can be reviewed and scanned with suitable handling, page sequencing and output rules.'],
    ['Can fragile documents be digitized safely?', 'Fragile records can often be digitized, but the process depends on paper condition. Tyrus reviews the archive and flags handling limitations before execution.'],
    ['Can old books be converted to searchable PDF?', 'Searchable PDF may be possible when print quality and language support allow reliable OCR. Otherwise, image PDF or PDF/A with indexing may be better.'],
    ['Do you provide archive metadata?', 'Yes. Metadata can include book title, register number, department, year, page range, subject and record category.']
  ]
};
---

<SeoServicePage {...props} />
