---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
const pageTitle = 'Banking & Finance Document Digitization | Tyrus Technologies';
---

<DefaultLayout
  title={pageTitle}
  description="Document digitization for banks and financial institutions in India. We digitize KYC, loan and account files so teams can access records faster with better control."
>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
        Industries · Banking &amp; Finance
      </p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900">
        Document digitization for banks and financial institutions.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        We digitize KYC forms, account opening files, loan documents and branch records so your operations,
        risk and audit teams can access information faster with better control.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-[1.2fr,1fr]">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Key record types.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• KYC and account opening forms.</li>
          <li>• Loan, mortgage and security documents.</li>
          <li>• Branch‑level registers and service records.</li>
          <li>• Credit card and payment‑related documentation.</li>
        </ul>
      </div>
      <div class="space-y-4 rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Controls built for BFSI</h3>
        <ul class="mt-2 space-y-2 text-sm text-slate-800">
          <li>• Batch tracking at carton, branch and product level.</li>
          <li>• Indexing by customer ID, account number and loan ID.</li>
          <li>• Clear logs of missing or incomplete files.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-2">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold text-slate-900">Benefits for banking operations.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Faster response to regulator and internal audit queries.</li>
          <li>• Easier branch consolidation and centralization of records.</li>
          <li>• Less time spent searching through cartons for customer files.</li>
        </ul>
      </div>
      <div class="space-y-3 rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Engagement examples</h3>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Branch‑wise scanning of legacy KYC and account files.</li>
          <li>• Centralized loan document digitization at a regional hub.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-xl font-semibold text-slate-900">
          Make your bank’s records easy to search and secure.
        </h2>
        <p class="mt-2 text-sm text-slate-700">
          Share your branch network, number of cartons and key document types. We will design a practical
          BFSI digitization model and cost estimate.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="/#cost-calculator"
            class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Get a free estimate
          </a>
          <a
            href="/contact"
            class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
          >
            Talk to our BFSI team
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

