---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
const pageTitle = 'Manufacturing & Corporate Document Digitization | Tyrus Technologies';
---

<DefaultLayout>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
        Industries · Manufacturing &amp; Corporate
      </p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900">
        Document digitization for manufacturing and large enterprises.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        We digitize plant records, QC documents, vendor and contract files, HR records and more so
        manufacturing and corporate teams can access information quickly and reduce storage overhead.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-[1.2fr,1fr]">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Typical records we handle.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Plant maintenance and equipment records.</li>
          <li>• Quality control and test reports.</li>
          <li>• Vendor contracts and purchasing documentation.</li>
          <li>• HR files for staff and contract workforce.</li>
        </ul>
      </div>
      <div class="space-y-4 rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Operations‑friendly organization</h3>
        <ul class="mt-2 space-y-2 text-sm text-slate-800">
          <li>• Indexing by plant, line, location, vendor or department.</li>
          <li>• Folder structures that mirror how your teams work today.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-2">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold text-slate-900">Benefits for manufacturing and corporate teams.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Faster access to records for audits and certifications.</li>
          <li>• Better tracking of contracts, warranties and SLAs.</li>
          <li>• Reduced space and handling costs for legacy files.</li>
        </ul>
      </div>
      <div class="space-y-3 rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Project examples</h3>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Digitization of plant QC archives across multiple locations.</li>
          <li>• Centralized contract and vendor record digitization for head office.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-xl font-semibold text-slate-900">
          Bring your manufacturing and corporate records into one digital view.
        </h2>
        <p class="mt-2 text-sm text-slate-700">
          Share your plant and office locations, record types and approximate volumes. We will propose
          a digitization roadmap and budget range that fits your operations.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="/#cost-calculator"
            class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Get a free estimate
          </a>
          <a
            href="/contact"
            class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
          >
            Talk to our enterprise team
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

