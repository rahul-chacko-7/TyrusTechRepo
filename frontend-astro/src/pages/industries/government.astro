---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
const pageTitle = 'Government Archive & Land Record Digitization | Tyrus Technologies';
---

<DefaultLayout
  title={pageTitle}
  description="Government record digitization for land files, citizen records, and department archives. Preserve historical documents and improve service delivery with searchable digital access."
>
  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">
        Industries · Government
      </p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900">
        Government record digitization &amp; archive scanning.
      </h1>
      <p class="mt-3 max-w-3xl text-sm text-slate-700">
        We support government departments and public sector organizations in digitizing land records,
        citizen records and department files to improve service delivery and preserve archives.
      </p>
    </div>
  </section>

  <section class="bg-slate-50 border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-[1.2fr,1fr]">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Types of records we handle.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Land and property records.</li>
          <li>• Citizen service files and application records.</li>
          <li>• Department correspondence and case files.</li>
          <li>• Historical archives that need careful preservation.</li>
        </ul>
      </div>
      <div class="space-y-4 rounded-2xl bg-white p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Approach for public sector work</h3>
        <ul class="mt-2 space-y-2 text-sm text-slate-800">
          <li>• On‑site teams working within government premises.</li>
          <li>• Detailed inventory and handover processes.</li>
          <li>• Support for tender‑based and rate‑contract engagements.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-white border-b border-slate-200">
    <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-2">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold text-slate-900">Benefits for departments and citizens.</h2>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• Faster access to files for citizen services and RTI responses.</li>
          <li>• Reduced risk of damage or loss of important records.</li>
          <li>• Better visibility into backlogs and status of digitization.</li>
        </ul>
      </div>
      <div class="space-y-3 rounded-2xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h3 class="text-sm font-semibold text-slate-900">Getting started</h3>
        <ul class="space-y-2 text-sm text-slate-800">
          <li>• We conduct a site survey to assess volumes and record conditions.</li>
          <li>• We propose a phased plan that fits department budgets and timelines.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-xl font-semibold text-slate-900">
          Modernize your department’s records with Tyrus.
        </h2>
        <p class="mt-2 text-sm text-slate-700">
          Share your department type, locations and approximate record volumes. We will recommend an
          approach that balances speed, budget and security.
        </p>
        <div class="mt-4 flex flex-wrap gap-3">
          <a
            href="/contact"
            class="rounded-full bg-emerald-600 px-5 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
          >
            Talk to our government team
          </a>
          <a
            href="/#cost-calculator"
            class="rounded-full border border-emerald-300 px-5 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50"
          >
            Get an estimate
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>

