---
import SeoServicePage from '../components/SeoServicePage.astro';

const props = {
  title: 'Large Format Document Scanning Services | Drawing & Blueprint Scanning | Tyrus',
  description: 'Large format document scanning services for drawings, maps, blueprints, plans, engineering records, archives, indexing and searchable digital output.',
  canonical: '/large-format-document-scanning-services',
  eyebrow: 'Large format scanning',
  h1: 'Large format document scanning services',
  serviceType: 'Large Format Document Scanning Services',
  intro: 'Tyrus Technologies digitizes drawings, blueprints, maps, plans, oversized registers and engineering archives into clean digital files with indexing, naming and secure archive output.',
  primaryItems: [
    'Large format scanning for engineering drawings, plant layouts, maps, plans, survey sheets and oversized records.',
    'Output to PDF, TIFF, JPEG or project-wise folders based on retrieval and archive needs.',
    'Indexing by drawing number, project, site, department, revision, date, asset, location or document type.',
    'Careful handling for old, folded, fragile or mixed-size documents.',
    'Useful for facility teams, engineering teams, manufacturing plants, real estate, infrastructure and public-sector archives.'
  ],
  outputs: [
    'Large format PDF, TIFF or image files',
    'Project-wise or drawing-number-wise folders',
    'Excel or CSV drawing index',
    'Revision and department-wise metadata',
    'Archive-ready digital handover',
    'Exception reports for damaged or unclear documents'
  ],
  process: [
    ['Review formats', 'We check size, condition, folding, numbering, project references and output expectations.'],
    ['Prepare and track', 'Drawings are sorted, sequenced and tracked before scanning.'],
    ['Scan and enhance', 'Large documents are scanned with attention to legibility, orientation, crop and contrast.'],
    ['Index and deliver', 'Files are named, indexed and delivered in project-ready or archive-ready folders.']
  ],
  trustItems: [
    'Designed for oversized and technical records that cannot be handled like normal office paper.',
    'Supports document control teams that need drawing numbers, revisions and project references preserved.',
    'Can be paired with onsite scanning when engineering records cannot leave the premises.'
  ],
  costFactors: [
    'Document size, condition, folding, fragility and preparation effort.',
    'File format, indexing fields, drawing number cleanup and revision mapping.',
    'Onsite scanning requirement, number of projects, and delivery timeline.'
  ],
  relatedLinks: [
    ['Document scanning services', '/document-scanning-services-india', 'For regular office records and archive scanning.'],
    ['Onsite document scanning', '/onsite-document-scanning-services', 'For sensitive records that need scanning at your premises.'],
    ['Document conversion services', '/document-conversion-services-india', 'For converting physical archives into digital formats.'],
    ['Bulk document scanning', '/bulk-document-scanning-services', 'For high-volume archive and record-room projects.']
  ],
  industries: [
    'Manufacturing and plant engineering teams',
    'Construction and infrastructure companies',
    'Real estate and facilities teams',
    'Government engineering departments',
    'Utilities and public works teams',
    'Education and institutional archives'
  ],
  faqs: [
    ['What is large format document scanning?', 'It is scanning for oversized documents such as drawings, maps, blueprints, plans and engineering records that need special handling and output control.'],
    ['Can drawings be indexed by drawing number?', 'Yes. Drawing number, project, revision, department, site and date can be captured as metadata fields.'],
    ['Can old folded drawings be scanned?', 'Yes. Old or folded drawings can be reviewed and handled carefully, with exceptions flagged when paper condition affects output.'],
    ['Can output be delivered as PDF or TIFF?', 'Yes. Common outputs include PDF, TIFF, JPEG and structured folders with Excel or CSV indexes.']
  ]
};
---

<SeoServicePage {...props} />
