---
layout: DefaultLayout

const { slug } = Astro.params;
const post = await import(`./${slug}.md`);
const { Content, frontmatter } = post;
---

<section class="bg-slate-950">
  <div class="mx-auto max-w-3xl px-4 py-16">
    <header class="mb-6 space-y-2">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-300">
        {frontmatter.category}
      </p>
      <h1 class="text-3xl font-semibold text-slate-50">{frontmatter.title}</h1>
      <p class="text-xs text-slate-500">
        {new Date(frontmatter.date).toLocaleDateString('en-IN', {
          day: '2-digit',
          month: 'short',
          year: 'numeric'
        })}
      </p>
      {frontmatter.seoDescription && (
        <p class="max-w-2xl text-sm text-slate-300">
          {frontmatter.seoDescription}
        </p>
      )}
    </header>

    <article class="prose prose-invert max-w-none prose-headings:text-slate-50 prose-p:text-slate-200 prose-a:text-emerald-300">
      <Content />
    </article>
  </div>
</section>

