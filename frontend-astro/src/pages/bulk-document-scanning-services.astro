  intro: 'Tyrus Technologies helps organizations convert large paper archives into structured digital records. We plan bulk document scanning projects with trained manpower, high-speed scanners, batching, image quality checks, OCR, indexing, and secure handover.',
  primaryItems: [
    'Bulk scanning for cartons, record rooms, branch files, legacy archives, registers, and department-wise files.',
    'Project planning for scanner capacity, manpower, daily output targets, and quality checkpoints.',
    'Batch-level tracking and chain-of-custody controls for large volumes and multi-location projects.',
    'Digital delivery with searchable PDFs, metadata sheets, archive folders, and exception reports.'
  ],
  outputs: [
    'Searchable digital archive by branch, department, year, customer, or file number',
    'Bulk OCR output with quality-controlled searchable PDFs',
    'Metadata index for retrieval and audit support',
    'Batch reports, exception logs, and final handover summary',
    'Secure transfer or drive-based handover'
  ],
  process: [
