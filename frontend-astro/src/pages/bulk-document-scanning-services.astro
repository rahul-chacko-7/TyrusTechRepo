---
import SeoServicePage from '../components/SeoServicePage.astro';

const props = {
  title: 'Bulk Document Scanning Services in India | Tyrus Technologies',
  description: 'Bulk document scanning services for high-volume archives, record rooms, cartons, files, and legacy documents across India with OCR, indexing, QC, and secure delivery.',
  canonical: '/bulk-document-scanning-services',
  eyebrow: 'Large archive conversion',
  h1: 'Bulk document scanning services in India',
  serviceType: 'Bulk Document Scanning Services',
  intro: 'Tyrus Technologies helps organizations convert large paper archives into structured digital records. We plan bulk document scanning projects with trained manpower, high-speed scanners, batching, image quality checks, OCR, indexing, and secure handover.',
  primaryItems: [
    'Bulk scanning for cartons, record rooms, branch files, legacy archives, registers, and department-wise files.',
    'Project planning for scanner capacity, manpower, daily output targets, and quality checkpoints.',
    'Batch-level tracking and chain-of-custody controls for large volumes and multi-location projects.',
    'Digital delivery with searchable PDFs, metadata sheets, archive folders, and exception reports.'
  ],
  outputs: [
    'Searchable digital archive by branch, department, year, customer, or file number',
    'Bulk OCR output with quality-controlled searchable PDFs',
    'Metadata index for retrieval and audit support',
    'Batch reports, exception logs, and final handover summary',
    'Secure transfer or drive-based handover'
  ],
  process: [
    ['Survey', 'We estimate page volume, file condition, document mix, and site constraints.'],
    ['Plan', 'We define batching, manpower, equipment, daily targets, and acceptance criteria.'],
    ['Execute', 'Teams prepare, scan, enhance, OCR, index, and verify documents in controlled batches.'],
    ['Close', 'We reconcile batches, deliver digital output, and return or store physical records as agreed.']
  ],
  industries: [
    'Corporate record rooms',
    'Banking branch files and KYC archives',
    'Hospital MRD rooms',
    'Government department archives',
    'Education records and student files',
    'Manufacturing plant and compliance records'
  ],
  faqs: [
    ['How do you estimate bulk scanning cost?', 'Cost depends on page volume, document condition, scanning location, indexing fields, OCR needs, output format, and timeline.'],
    ['Can you scan millions of pages?', 'Yes. Tyrus can plan phased manpower and equipment deployment for very large archive conversion projects.'],
    ['How do you avoid missing pages?', 'Projects use batching, file tracking, image quality checks, index verification, and reconciliation before handover.'],
    ['Can physical files be returned in the same order?', 'Yes. File sequence and batch structure can be maintained so records are returned in the required order.']
  ]
};
