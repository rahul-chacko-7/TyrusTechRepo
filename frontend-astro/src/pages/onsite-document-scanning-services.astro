---
import SeoServicePage from '../components/SeoServicePage.astro';

const props = {
  title: 'Onsite Document Scanning Services in India | Tyrus Technologies',
  description: 'Onsite document scanning services in India for confidential files, hospital records, banking KYC, legal documents, and government archives that cannot leave premises.',
  canonical: '/onsite-document-scanning-services',
  eyebrow: 'Scan at your premises',
  h1: 'Onsite document scanning services',
  serviceType: 'Onsite Document Scanning Services',
  intro: 'When sensitive records cannot leave your premises, Tyrus Technologies deploys trained scanning teams, scanners, consumables, and quality workflows at your location. Onsite scanning keeps physical files under your supervision while still creating searchable digital archives.',
  primaryItems: [
    'Onsite scanning setup for hospitals, banks, government departments, legal teams, and enterprise offices.',
    'Controlled access workflows for confidential documents and restricted record rooms.',
    'Daily scanning output planning, supervisor reporting, exception handling, and secure digital handover.',
    'OCR, indexing, image enhancement, metadata capture, and DMS-ready output from the onsite setup.'
  ],
  outputs: [
    'Searchable PDF or image files generated at your premises',
    'File indexes by patient, customer, department, case, employee, or record number',
    'Daily productivity and quality reports',
    'Secure local handover or approved cloud transfer',
    'Physical records retained at your site'
  ],
  process: [
    ['Site survey', 'We review available space, power, security rules, file movement, and required output.'],
    ['Setup', 'Scanning stations, operators, supervisors, and tracking workflows are deployed at your premises.'],
    ['Digitize', 'Files are prepared, scanned, enhanced, OCR processed, indexed, and checked onsite.'],
    ['Handover', 'Approved digital output is transferred securely and physical records remain under your control.']
  ],
  industries: [
    'Hospitals and confidential MRD archives',
    'Banks and NBFC branches',
    'Government record rooms',
    'Law firms and legal departments',
    'Insurance and financial operations',
    'Enterprise HR, finance, and compliance teams'
  ],
  faqs: [
    ['When should we choose onsite scanning?', 'Choose onsite scanning when documents are confidential, legally restricted, operationally active, fragile, or difficult to transport.'],
    ['Do you bring scanners and staff?', 'Yes. Tyrus can deploy scanners, operators, supervisors, and project workflows based on volume and timeline.'],
    ['Can we monitor the work?', 'Yes. Onsite projects can include daily reporting, supervisor review, and client-side access controls.'],
    ['Can onsite files be made searchable?', 'Yes. OCR, indexing, metadata capture, and searchable PDF output can be included in onsite scanning.']
  ]
};
---

<SeoServicePage {...props} />
