---
import DefaultLayout from '../../../layouts/DefaultLayout.astro';
import { serviceLocationPages, serviceLocationTypes } from '../../../data/locationPages';

export const prerender = true;

export function getStaticPaths() {
  return serviceLocationPages.map((page) => ({
    params: {
      city: page.citySlug,
      service: page.serviceSlug
    },
    props: page
  }));
}

const { location, service } = Astro.props;
const pageTitle = `${service.titlePrefix} in ${location.city} | Tyrus Technologies`;
const pageDescription = `${service.titlePrefix} in ${location.city} for enterprises: ${service.serviceIntro}, secure handling, onsite support and structured digital output.`;
const otherServices = serviceLocationTypes.filter((item) => item.slug !== service.slug);

const faqItems = [
  [
    `Do you provide ${service.keyword} in ${location.city}?`,
    `Yes. Tyrus provides ${service.keyword} in ${location.city} and nearby business areas including ${location.nearby}.`
  ],
  [
    `Can this work be done onsite in ${location.city}?`,
    `Yes. Tyrus can plan onsite scanning in ${location.city} when documents are confidential, active, restricted or difficult to move from your premises.`
  ],
  [
    'What output can we receive?',
    'Typical output includes searchable PDF, PDF/A, TIFF or image files, OCR text, metadata index sheets, folder structures and DMS-ready handover packages.'
  ],
  [
    `How do we get a quote for ${location.city}?`,
    'Share page volume, document types, number of files or boxes, location, onsite or offsite preference, indexing fields and timeline.'
  ]
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(([question, answer]) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer
    }
  }))
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.label} in ${location.city}`,
  serviceType: service.label,
  provider: {
    '@type': 'Organization',
    name: 'Tyrus Technologies Pvt Ltd',
    url: 'https://www.tyrustech.com'
  },
  areaServed: {
    '@type': 'City',
    name: location.city
  },
  description: pageDescription
};
---

<DefaultLayout title={pageTitle} description={pageDescription} schemas={[serviceSchema, faqSchema]}>
  <section class="border-b border-emerald-100 bg-gradient-to-b from-emerald-950 via-emerald-900 to-emerald-800">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-[1.2fr,0.8fr] md:items-center md:py-20">
      <div>
        <p class="inline-flex rounded-full border border-emerald-300/40 bg-emerald-800/70 px-3 py-1 text-xs font-semibold text-emerald-100">
          {location.city} | {service.label}
        </p>
        <h1 class="mt-5 text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl">
          {service.titlePrefix} in {location.city}
        </h1>
        <p class="mt-5 max-w-3xl text-sm leading-7 text-emerald-50/90 sm:text-base">
          Tyrus helps teams in {location.city} {service.primaryNeed}. Projects can include {service.serviceIntro}, with secure handling and clear project reporting.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contact" class="rounded-full bg-emerald-400 px-6 py-2 text-sm font-semibold text-emerald-950 shadow-lg shadow-emerald-950/30 hover:bg-white">
            Get a local quote
          </a>
          <a href="/#cost-calculator" class="rounded-full border border-emerald-200/70 px-6 py-2 text-sm font-semibold text-emerald-50 hover:bg-emerald-700/70">
            Estimate pages
          </a>
        </div>
      </div>
      <div class="rounded-3xl border border-emerald-200/30 bg-emerald-950/55 p-5 shadow-2xl shadow-emerald-950/50">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-200">Coverage</p>
        <p class="mt-4 text-sm leading-7 text-emerald-50">{location.nearby}</p>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-14 md:grid-cols-[1fr,1fr]">
      <div>
        <h2 class="text-2xl font-semibold text-slate-900">What this service includes in {location.city}</h2>
        <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-700">
          {[
            'Document preparation, de-stapling, sorting, batching and file movement planning.',
            'Scanning with image quality checks, page sequence review and exception handling.',
            'OCR, searchable PDF, metadata capture and index sheet creation where required.',
            'Onsite or offsite project model based on confidentiality, volume, timeline and logistics.',
            'DMS, EMR, ERP, cloud, SFTP or secure-drive handover with structured folders.'
          ].map((item) => (
            <li class="flex gap-3">
              <span class="mt-3 h-1.5 w-1.5 flex-none rounded-full bg-emerald-500"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-3xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h2 class="text-xl font-semibold text-slate-900">Records commonly handled</h2>
        <div class="mt-5 grid gap-3">
          {[
            'Office files, invoices, vouchers and finance records',
            'KYC files, loan documents and branch records',
            'Medical records, MRD files, OPD and IPD case sheets',
            'Contracts, legal files, HR folders and compliance records',
            'Registers, government archives, land records and old cartons'
          ].map((item) => (
            <div class="rounded-2xl bg-white p-4 text-sm font-semibold text-slate-900 ring-1 ring-slate-200">{item}</div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Industries supported in {location.city}</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {location.industries.map((item) => (
          <div class="rounded-2xl bg-white p-5 text-sm font-semibold text-slate-900 ring-1 ring-slate-200">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-6 px-4 py-14 lg:grid-cols-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">Security</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">Controlled document handling</h2>
        <p class="mt-4 text-sm leading-7 text-slate-700">
          Projects can include restricted staff access, batch logs, file movement tracking, exception reporting and secure digital transfer.
        </p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">Searchability</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">OCR and metadata</h2>
        <p class="mt-4 text-sm leading-7 text-slate-700">
          Index fields can include customer ID, MRN, file number, invoice number, department, branch, date, vendor, year or record type.
        </p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-600">Planning</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">Quote factors</h2>
        <p class="mt-4 text-sm leading-7 text-slate-700">
          Cost depends on page volume, file condition, preparation work, OCR, indexing fields, onsite setup, locations and timeline.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Related {location.city} services</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {otherServices.map((item) => (
          <a href={`/locations/${location.slug}/${item.slug}`} class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 transition hover:ring-emerald-300">
            <h3 class="text-sm font-semibold text-slate-900">{item.titlePrefix} in {location.city}</h3>
            <p class="mt-2 text-xs leading-6 text-slate-600">{item.primaryNeed}</p>
          </a>
        ))}
        <a href={`/locations/${location.slug}`} class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 transition hover:ring-emerald-300">
          <h3 class="text-sm font-semibold text-slate-900">All document services in {location.city}</h3>
          <p class="mt-2 text-xs leading-6 text-slate-600">View the main city page for scanning, digitization, OCR and archive services.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Frequently asked questions</h2>
      <div class="mt-6 space-y-4">
        {faqItems.map(([question, answer]) => (
          <details class="rounded-2xl bg-slate-50 p-5 ring-1 ring-slate-200">
            <summary class="cursor-pointer text-sm font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-7 text-slate-700">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-2xl font-semibold text-slate-900">Get a {service.label.toLowerCase()} quote in {location.city}</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-700">
          Share page volume, file types, locations, onsite requirement, OCR and indexing fields, output format and timeline. Tyrus will suggest a practical project plan.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/contact" class="rounded-full bg-emerald-600 px-6 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700">Contact Tyrus</a>
          <a href="/locations" class="rounded-full border border-emerald-300 px-6 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50">View all cities</a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
