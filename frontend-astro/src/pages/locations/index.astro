---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
import { locationPages, locationServices } from '../../data/locationPages';

const pageTitle = 'Document Scanning and Digitization Services by City | Tyrus';
const pageDescription =
  'Tyrus provides document scanning, document digitization, bulk scanning, onsite scanning and OCR indexing services across major Indian cities.';
---

<DefaultLayout
  title={pageTitle}
  description={pageDescription}
>
  <section class="border-b border-emerald-100 bg-gradient-to-b from-emerald-950 via-emerald-900 to-emerald-800">
    <div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <p class="inline-flex rounded-full border border-emerald-300/40 bg-emerald-800/70 px-3 py-1 text-xs font-semibold text-emerald-100">
        India service areas
      </p>
      <h1 class="mt-5 max-w-4xl text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl">
        Document scanning and digitization services across major Indian cities
      </h1>
      <p class="mt-5 max-w-3xl text-sm leading-7 text-emerald-50/90 sm:text-base">
        Tyrus supports India-wide document scanning, document digitization, bulk archive conversion, onsite document scanning, OCR indexing, metadata capture and DMS-ready digital archive projects.
      </p>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-semibold text-slate-900">Choose your city</h2>
        <p class="mt-3 text-sm leading-7 text-slate-700">
          These city pages help teams find document scanning services near their office, hospital, branch, record room or archive location.
        </p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {locationPages.map((location) => (
          <a href={`/locations/${location.slug}`} class="rounded-2xl bg-slate-50 p-5 ring-1 ring-slate-200 transition hover:ring-emerald-300">
            <h2 class="text-sm font-semibold text-slate-900">Document scanning services in {location.city}</h2>
            <p class="mt-2 text-xs leading-6 text-slate-600">{location.region}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Services available across locations</h2>
      <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {locationServices.map((service) => (
          <div class="rounded-2xl bg-white p-4 text-sm font-semibold text-slate-900 ring-1 ring-slate-200">{service}</div>
        ))}
      </div>
    </div>
  </section>
</DefaultLayout>
