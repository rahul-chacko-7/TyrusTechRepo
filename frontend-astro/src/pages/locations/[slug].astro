---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
import { locationPages, locationServices, serviceLocationTypes } from '../../data/locationPages';

export const prerender = true;

export function getStaticPaths() {
  return locationPages.map((location) => ({
    params: { slug: location.slug },
    props: { location }
  }));
}

const { location } = Astro.props;
const pageTitle = `Document Scanning Services in ${location.city} | Digitization & OCR - Tyrus`;
const pageDescription = `Document scanning services in ${location.city}: bulk document scanning, onsite scanning, OCR indexing, metadata capture and DMS-ready digitization for enterprises.`;

const faqItems = [
  [
    `Do you provide document scanning services in ${location.city}?`,
    `Yes. Tyrus provides document scanning, document digitization, bulk scanning, onsite scanning and OCR indexing services for organizations in ${location.city} and nearby business areas.`
  ],
  [
    `Can scanning be done onsite in ${location.city}?`,
    `Yes. Onsite document scanning can be planned in ${location.city} when files are confidential, active, restricted or difficult to move from your premises.`
  ],
  [
    `What files can Tyrus digitize in ${location.city}?`,
    'Tyrus can digitize office files, medical records, KYC files, loan files, invoices, HR records, contracts, registers, government archives and legacy record-room documents.'
  ],
  [
    `Can scanned files be searchable?`,
    'Yes. Output can include searchable PDF, PDF/A, OCR text, metadata sheets, folder structures and DMS-ready archive files.'
  ]
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(([question, answer]) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer
    }
  }))
};
---

<DefaultLayout
  title={pageTitle}
  description={pageDescription}
  schemas={[faqSchema]}
>
  <section class="border-b border-emerald-100 bg-gradient-to-b from-emerald-950 via-emerald-900 to-emerald-800">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-16 md:grid-cols-[1.2fr,0.8fr] md:items-center md:py-20">
      <div>
        <p class="inline-flex rounded-full border border-emerald-300/40 bg-emerald-800/70 px-3 py-1 text-xs font-semibold text-emerald-100">
          {location.city} document digitization
        </p>
        <h1 class="mt-5 text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl">
          Document scanning services in {location.city}
        </h1>
        <p class="mt-5 max-w-3xl text-sm leading-7 text-emerald-50/90 sm:text-base">
          {location.intro}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/contact" class="rounded-full bg-emerald-400 px-6 py-2 text-sm font-semibold text-emerald-950 shadow-lg shadow-emerald-950/30 hover:bg-white">
            Get a quote
          </a>
          <a href="/#cost-calculator" class="rounded-full border border-emerald-200/70 px-6 py-2 text-sm font-semibold text-emerald-50 hover:bg-emerald-700/70">
            Estimate pages
          </a>
        </div>
      </div>
      <div class="rounded-3xl border border-emerald-200/30 bg-emerald-950/55 p-5 shadow-2xl shadow-emerald-950/50">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-200">Coverage</p>
        <p class="mt-4 text-sm leading-7 text-emerald-50">{location.nearby}</p>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-14 md:grid-cols-[1fr,1fr]">
      <div>
        <h2 class="text-2xl font-semibold text-slate-900">Services available in {location.city}</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {locationServices.map((service) => (
            <div class="rounded-2xl bg-slate-50 p-4 text-sm font-semibold text-slate-900 ring-1 ring-slate-200">
              {service} in {location.city}
            </div>
          ))}
        </div>
      </div>
      <div class="rounded-3xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h2 class="text-xl font-semibold text-slate-900">Typical outputs</h2>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-800">
          {[
            'Searchable PDF, PDF/A, TIFF, JPEG or PNG files',
            'OCR text extraction and metadata capture',
            'Excel or CSV index sheets for retrieval',
            'DMS, EMR, ERP or cloud-ready folder structures',
            'Batch reports, exception logs and secure handover'
          ].map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-sky-500"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-semibold text-slate-900">Popular local service pages in {location.city}</h2>
        <p class="mt-3 text-sm leading-7 text-slate-700">
          These pages target specific local searches for scanning, digitization and bulk archive conversion in {location.city}.
        </p>
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {serviceLocationTypes.map((service) => (
          <a href={`/locations/${location.slug}/${service.slug}`} class="rounded-2xl bg-white p-5 ring-1 ring-slate-200 transition hover:ring-emerald-300">
            <h3 class="text-sm font-semibold text-slate-900">{service.titlePrefix} in {location.city}</h3>
            <p class="mt-2 text-xs leading-6 text-slate-600">{service.primaryNeed}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Industries and records covered in {location.city}</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {location.industries.map((item) => (
          <div class="rounded-2xl bg-white p-5 text-sm font-semibold text-slate-900 ring-1 ring-slate-200">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-6 px-4 py-14 lg:grid-cols-3">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">Project models</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">Onsite and offsite scanning</h2>
        <p class="mt-4 text-sm leading-7 text-slate-700">
          Choose onsite document scanning in {location.city} when records must remain in your office, hospital, branch or archive room. Offsite scanning can be planned when logistics, timeline and security rules allow controlled movement.
        </p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">Search and retrieval</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">OCR and indexing</h2>
        <p class="mt-4 text-sm leading-7 text-slate-700">
          Tyrus can create searchable PDFs, metadata indexes, file naming rules, branch-wise folders, patient-wise archives, customer-wise KYC records and DMS-ready output.
        </p>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-600">Cost planning</p>
        <h2 class="mt-2 text-xl font-semibold text-slate-900">What affects price</h2>
        <p class="mt-4 text-sm leading-7 text-slate-700">
          Pricing depends on page volume, document condition, city location, onsite setup, indexing fields, OCR requirements, output format, timeline and number of sites.
        </p>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Frequently asked questions</h2>
      <div class="mt-6 space-y-4">
        {faqItems.map(([question, answer]) => (
          <details class="rounded-2xl bg-white p-5 ring-1 ring-slate-200">
            <summary class="cursor-pointer text-sm font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-7 text-slate-700">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-2xl font-semibold text-slate-900">Get a document scanning quote in {location.city}</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-700">
          Share page volume, document type, locations, timeline and output requirements. Tyrus will suggest the right scanning model, manpower plan, OCR and indexing scope.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/contact" class="rounded-full bg-emerald-600 px-6 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700">Contact Tyrus</a>
          <a href="/locations" class="rounded-full border border-emerald-300 px-6 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50">View all cities</a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
