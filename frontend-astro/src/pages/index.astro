---
import DefaultLayout from '../layouts/DefaultLayout.astro';
const pageTitle = 'Document Digitization Services India';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<DefaultLayout
  title={pageTitle}
  description="Secure, high-speed document digitization services across India for hospitals, banks, government, legal firms and enterprises."
>

<section class="border-b border-emerald-100 bg-gradient-to-b from-emerald-900 via-emerald-800 to-emerald-700">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-10 sm:py-12 md:flex-row md:items-center md:gap-10 md:py-20">
    <!-- Left: text -->
    <div class="flex-1 space-y-5 text-center md:text-left">
      <p class="inline-flex items-center justify-center gap-2 rounded-full border border-emerald-300/40 bg-emerald-800/70 px-3 py-1 text-[11px] font-medium text-emerald-100 md:justify-start">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
        Trusted document digitization partner across India
      </p>

      <h1 class="text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl">
        Secure Document Digitization Services in India
      </h1>

      <p class="max-w-xl mx-auto text-balance text-xs text-emerald-50/90 sm:text-sm md:mx-0 md:text-base">
        High-speed, secure document digitization for hospitals, banks, government, legal firms, and enterprises.
        Turn paper archives into searchable, compliant digital records while reducing your carbon footprint.
      </p>

      <div class="flex flex-wrap justify-center gap-3 md:justify-start">
        <a
          href="#cost-calculator"
          class="rounded-full bg-emerald-400 px-6 py-2 text-sm font-semibold text-emerald-950 shadow-lg shadow-emerald-900/40 transition hover:bg-white"
        >
          Get a Free Estimate
        </a>
        <a
          href="/contact"
          class="rounded-full border border-emerald-200/70 px-6 py-2 text-sm font-semibold text-emerald-50 hover:bg-emerald-700/60"
        >
          Talk to an Expert
        </a>
      </div>

      <div class="flex flex-wrap justify-center gap-3 text-[11px] text-emerald-100/90 md:justify-start">
        <span>✓ HIPAA-ready medical record digitization</span>
        <span>✓ Secure legal & government archives</span>
        <span>✓ Pan-India on-site scanning</span>
      </div>
    </div>

    <!-- Right: stats card -->
    <div class="flex-1 w-full">
      <div class="mx-auto max-w-md rounded-2xl border border-emerald-200/40 bg-emerald-900/70 p-5 shadow-2xl shadow-emerald-950/70 sm:p-6">
        <h2 class="mb-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-100">
          Why teams choose Tyrus
        </h2>
        <p class="mb-5 text-[11px] text-emerald-100/80">
          Why leading organizations across India choose our digitization workflows.
        </p>
        <dl class="grid grid-cols-1 gap-3 text-sm text-emerald-50 sm:grid-cols-3">
          <div class="rounded-lg bg-emerald-900/80 p-3 ring-1 ring-emerald-700/60">
            <dt class="mb-1 text-[11px] font-medium uppercase tracking-wide text-emerald-200">
              Sustainability
            </dt>
            <dd class="text-base font-semibold text-emerald-200">
              Paperless-first
            </dd>
            <p class="mt-1 text-[11px] text-emerald-100/80">
              Reduce storage rooms, paper usage, and logistics.
            </p>
          </div>
          <div class="rounded-lg bg-emerald-900/80 p-3 ring-1 ring-emerald-700/60">
            <dt class="mb-1 text-[11px] font-medium uppercase tracking-wide text-emerald-200">
              Security
            </dt>
            <dd class="text-base font-semibold text-emerald-200">
              Enterprise-grade
            </dd>
            <p class="mt-1 text-[11px] text-emerald-100/80">
              Controlled access, encrypted workflows, and NDA-backed staff.
            </p>
          </div>
          <div class="rounded-lg bg-emerald-900/80 p-3 ring-1 ring-emerald-700/60">
            <dt class="mb-1 text-[11px] font-medium uppercase tracking-wide text-emerald-200">
              Efficiency
            </dt>
            <dd class="text-base font-semibold text-emerald-200">
              High throughput
            </dd>
            <p class="mt-1 text-[11px] text-emerald-100/80">
              Millions of pages digitized with SLA-backed timelines.
            </p>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>

<section id="sustainability" class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-16 md:grid-cols-[1.2fr,1fr]">
    <div class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-50">
        Go Green with paperless, space-saving digital archives.
      </h2>
      <p class="text-sm text-slate-300">
        Physical files consume real estate, logistics, and trees. Our digitization programs convert
        records into compact, cloud-ready archives that align with your organization&rsquo;s
        sustainability goals.
      </p>
      <ul class="mt-4 grid gap-3 text-sm text-slate-200 sm:grid-cols-2">
        <li class="flex items-start gap-2">
          <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          <span>Reduce paper consumption and printing overheads.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          <span>Free up storage rooms, warehouses, and office space.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          <span>Lower logistics and transportation emissions.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          <span>Enable hybrid and remote teams with digital access.</span>
        </li>
      </ul>
    </div>
    <div class="space-y-4 rounded-2xl bg-gradient-to-br from-emerald-500/10 via-sky-500/5 to-slate-900 p-6 ring-1 ring-emerald-400/20">
      <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-emerald-300">
        Sustainability impact
      </h3>
      <p class="text-xs text-slate-300">
        Typical outcomes when organizations shift large archives to digital.
      </p>
      <dl class="space-y-3 text-sm">
        <div class="flex items-center justify-between rounded-lg bg-slate-950/60 px-4 py-3">
          <dt class="text-slate-300">Storage space saved</dt>
          <dd class="font-semibold text-emerald-300">60–80%</dd>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-slate-950/60 px-4 py-3">
          <dt class="text-slate-300">Paper usage reduction</dt>
          <dd class="font-semibold text-emerald-300">Up to 70%</dd>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-slate-950/60 px-4 py-3">
          <dt class="text-slate-300">Carbon footprint</dt>
          <dd class="font-semibold text-emerald-300">Lower logistics & printing</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<section id="security" class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-10 md:grid-cols-[1.1fr,1.1fr]">
      <div class="space-y-4">
        <h2 class="text-2xl font-semibold text-slate-50">
          Secure handling for highly sensitive records.
        </h2>
        <p class="text-sm text-slate-300">
          From medical records and KYC documents to legal case files and government archives, our
          workflows are designed for confidentiality and compliance.
        </p>
        <ul class="mt-4 space-y-3 text-sm text-slate-200">
          <li class="flex gap-2">
            <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            <span>Controlled access zones for physical documents.</span>
          </li>
          <li class="flex gap-2">
            <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            <span>Background-verified operators and NDA-backed staff.</span>
          </li>
          <li class="flex gap-2">
            <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            <span>Encrypted data transfer and secure storage options.</span>
          </li>
          <li class="flex gap-2">
            <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
            <span>Audit trails for document movement and access.</span>
          </li>
        </ul>
      </div>
      <div class="space-y-4 rounded-2xl bg-slate-950/80 p-6 ring-1 ring-slate-700/80">
        <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-sky-300">
          Designed for regulated industries
        </h3>
        <p class="text-xs text-slate-300">
          Frameworks to support healthcare, BFSI, government, and legal compliance requirements.
        </p>
        <div class="grid gap-3 text-sm sm:grid-cols-2">
          <div class="rounded-lg bg-slate-900/80 p-4">
            <p class="text-xs font-medium uppercase tracking-wide text-slate-400">Healthcare</p>
            <p class="mt-1 text-slate-100">OPD/IPD, radiology, and EMR-ready archives.</p>
          </div>
          <div class="rounded-lg bg-slate-900/80 p-4">
            <p class="text-xs font-medium uppercase tracking-wide text-slate-400">Banking & KYC</p>
            <p class="mt-1 text-slate-100">Account, loan, and KYC bundles digitized securely.</p>
          </div>
          <div class="rounded-lg bg-slate-900/80 p-4">
            <p class="text-xs font-medium uppercase tracking-wide text-slate-400">Government</p>
            <p class="mt-1 text-slate-100">Archives, land records, and citizen files.</p>
          </div>
          <div class="rounded-lg bg-slate-900/80 p-4">
            <p class="text-xs font-medium uppercase tracking-wide text-slate-400">Legal</p>
            <p class="mt-1 text-slate-100">Case files, contracts, and evidence bundles.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="services" class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-slate-50">Digitization & scanning services.</h2>
        <p class="mt-2 max-w-xl text-sm text-slate-300">
          Modular services you can combine into a complete paperless transformation program.
        </p>
      </div>
      <a
        href="/services"
        class="text-sm font-medium text-emerald-300 hover:text-emerald-200"
      >
        View all services →
      </a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      <div class="rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
        <h3 class="text-sm font-semibold text-slate-50">Document Digitization</h3>
        <p class="mt-2 text-xs text-slate-300">
          End-to-end paper-to-digital conversion for corporate, government, and institutional records.
        </p>
      </div>
      <div class="rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
        <h3 class="text-sm font-semibold text-slate-50">Document Scanning</h3>
        <p class="mt-2 text-xs text-slate-300">
          High-speed scanners with quality checks, indexing, and barcode-based batching.
        </p>
      </div>
      <div class="rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
        <h3 class="text-sm font-semibold text-slate-50">Data Capture</h3>
        <p class="mt-2 text-xs text-slate-300">
          OCR and structured data capture into ERPs, EMRs, and line-of-business systems.
        </p>
      </div>
      <div class="rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
        <h3 class="text-sm font-semibold text-slate-50">Digital Archives</h3>
        <p class="mt-2 text-xs text-slate-300">
          Searchable, role-based archives with retention policies and fast retrieval.
        </p>
      </div>
      <div class="rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
        <h3 class="text-sm font-semibold text-slate-50">Medical Record Digitization</h3>
        <p class="mt-2 text-xs text-slate-300">
          OPD/IPD file scanning, MRD workflows, and EMR integration-ready datasets.
        </p>
      </div>
      <div class="rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
        <h3 class="text-sm font-semibold text-slate-50">Legal Document Digitization</h3>
        <p class="mt-2 text-xs text-slate-300">
          Matter-wise bundling, evidence digitization, and secure e-brief creation.
        </p>
      </div>
    </div>
  </div>
</section>

<section
  id="cost-calculator"
  class="border-b border-slate-800 bg-gradient-to-b from-slate-950 via-slate-950 to-slate-900"
>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-8 max-w-2xl space-y-3">
      <h2 class="text-2xl font-semibold text-slate-50">Instant digitization cost estimate.</h2>
      <p class="text-sm text-slate-300">
        Get an approximate project budget and completion timeline based on your page volume and
        document type. Share your details to receive a detailed proposal in your inbox.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1.2fr),minmax(0,1fr)]">
      <div class="rounded-2xl bg-slate-950/80 p-6 ring-1 ring-slate-800">
        <form
          id="calculator-form"
          class="space-y-4 text-sm"
        >
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label for="pages" class="mb-1 block text-xs font-medium text-slate-300">
                Approximate number of pages
              </label>
              <input
                id="pages"
                name="pages"
                type="number"
                min="1"
                required
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 placeholder:text-slate-500 focus:border-emerald-400 focus:ring-2"
                placeholder="e.g. 25,000"
              />
            </div>
            <div>
              <label for="document_type" class="mb-1 block text-xs font-medium text-slate-300">
                Primary document type
              </label>
              <select
                id="document_type"
                name="document_type"
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 focus:border-emerald-400 focus:ring-2"
              >
                <option value="mixed">Mixed office files</option>
                <option value="medical">Medical records</option>
                <option value="legal">Legal files</option>
                <option value="banking">Banking & KYC</option>
                <option value="government">Government archives</option>
              </select>
            </div>
            <div>
              <label for="timeline" class="mb-1 block text-xs font-medium text-slate-300">
                Preferred timeline
              </label>
              <select
                id="timeline"
                name="timeline"
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 focus:border-emerald-400 focus:ring-2"
              >
                <option value="flexible">Flexible</option>
                <option value="standard">Standard (SLA-based)</option>
                <option value="expedited">Expedited</option>
              </select>
            </div>
            <div>
              <label for="location" class="mb-1 block text-xs font-medium text-slate-300">
                Project location / city
              </label>
              <input
                id="location"
                name="location"
                type="text"
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 placeholder:text-slate-500 focus:border-emerald-400 focus:ring-2"
                placeholder="e.g. Mumbai, Delhi, Bengaluru"
              />
            </div>
          </div>
          <p id="calculator-error" class="text-xs text-rose-400"></p>
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-full bg-emerald-500 px-5 py-2 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/30 transition hover:bg-emerald-400"
          >
            Calculate estimate
          </button>
          <p id="calculator-result" class="mt-3 text-xs text-emerald-200"></p>
        </form>
      </div>

      <div
        id="lead-form-card"
        class="hidden rounded-2xl bg-slate-950/80 p-6 ring-1 ring-emerald-500/40"
      >
        <h3 class="text-sm font-semibold text-slate-50">
          Get your detailed quotation & implementation plan.
        </h3>
        <p class="mt-1 text-xs text-slate-300">
          Share your details and our digitization experts will send a customized proposal for your
          organization.
        </p>

        <form
          id="lead-form"
          class="mt-4 space-y-3 text-sm"
        >
          <div class="grid gap-3 md:grid-cols-2">
            <div>
              <label for="name" class="mb-1 block text-xs font-medium text-slate-300">Name</label>
              <input
                id="name"
                name="name"
                required
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 placeholder:text-slate-500 focus:border-emerald-400 focus:ring-2"
                placeholder="Your full name"
              />
            </div>
            <div>
              <label for="company" class="mb-1 block text-xs font-medium text-slate-300">
                Organization / Company
              </label>
              <input
                id="company"
                name="company"
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 placeholder:text-slate-500 focus:border-emerald-400 focus:ring-2"
                placeholder="Hospital, bank, firm, etc."
              />
            </div>
            <div>
              <label for="email" class="mb-1 block text-xs font-medium text-slate-300">Work email</label>
              <input
                id="email"
                name="email"
                type="email"
                required
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 placeholder:text-slate-500 focus:border-emerald-400 focus:ring-2"
                placeholder="you@company.com"
              />
            </div>
            <div>
              <label for="phone" class="mb-1 block text-xs font-medium text-slate-300">Phone</label>
              <input
                id="phone"
                name="phone"
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 placeholder:text-slate-500 focus:border-emerald-400 focus:ring-2"
                placeholder="+91 ..."
              />
            </div>
            <div>
              <label for="city" class="mb-1 block text-xs font-medium text-slate-300">City</label>
              <input
                id="city"
                name="city"
                class="block w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-50 outline-none ring-emerald-500/40 placeholder:text-slate-500 focus:border-emerald-400 focus:ring-2"
                placeholder="Project location"
              />
            </div>
            <div>
              <label for="lead-pages" class="mb-1 block text-xs font-medium text-slate-300">
                Pages (auto-filled)
              </label>
              <input
                id="lead-pages"
                name="pages"
                readonly
                class="block w-full cursor-not-allowed rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-400"
              />
            </div>
            <div>
              <label for="lead-estimated-price" class="mb-1 block text-xs font-medium text-slate-300">
                Estimated price (₹)
              </label>
              <input
                id="lead-estimated-price"
                name="estimated_price"
                readonly
                class="block w-full cursor-not-allowed rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-sm text-slate-400"
              />
            </div>
          </div>
          <p id="lead-error" class="text-xs text-rose-400"></p>
          <p id="lead-success" class="text-xs text-emerald-300"></p>
          <button
            type="submit"
            class="mt-1 inline-flex items-center gap-2 rounded-full bg-emerald-500 px-5 py-2 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/30 transition hover:bg-emerald-400"
          >
            Send me a detailed quote
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<section id="industries" class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-slate-50">Industries we serve.</h2>
        <p class="mt-2 max-w-xl text-sm text-slate-300">
          Tailored workflows for hospitals, banks, government departments, legal firms, educational
          institutions, and large enterprises.
        </p>
      </div>
      <a
        href="/industries"
        class="text-sm font-medium text-emerald-300 hover:text-emerald-200"
      >
        Explore industry-specific solutions →
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {['Healthcare', 'Banking', 'Government', 'Legal', 'Education', 'Manufacturing', 'Insurance'].map(
        (industry) => (
          <div class="rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
            <h3 class="text-sm font-semibold text-slate-50">{industry}</h3>
            <p class="mt-2 text-xs text-slate-300">
              Digitization blueprints, indexing standards, and retrieval models built for {industry.toLowerCase()}.
            </p>
          </div>
        )
      )}
    </div>
  </div>
</section>

<section id="case-studies" class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-slate-50">Sample digitization projects.</h2>
        <p class="mt-2 max-w-xl text-sm text-slate-300">
          Real-world examples of how we help organizations move from paper-heavy operations to
          secure digital archives.
        </p>
      </div>
      <a
        href="/case-studies"
        class="text-sm font-medium text-emerald-300 hover:text-emerald-200"
      >
        View more case studies →
      </a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      <article class="flex flex-col rounded-2xl bg-slate-950/70 p-5 ring-1 ring-slate-800">
        <p class="text-xs font-medium uppercase tracking-wide text-emerald-300">
          Healthcare · 4.5M pages
        </p>
        <h3 class="mt-2 text-sm font-semibold text-slate-50">
          Multi-hospital medical record digitization.
        </h3>
        <p class="mt-2 flex-1 text-xs text-slate-300">
          Migrated legacy MRD archives into a searchable digital repository, improving retrieval
          times from hours to seconds.
        </p>
        <p class="mt-3 text-xs text-emerald-200">Result: 70% faster retrieval · MRD space freed.</p>
      </article>
