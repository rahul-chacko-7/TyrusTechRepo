<script type="module" define:vars={{ supabaseUrl, supabaseAnonKey }}>
  // Load Supabase client only when the user submits the lead form.
  // This reduces initial JS parsing/compilation time (Lighthouse Total Blocking Time).
  let supabaseClient;
  async function getSupabaseClient() {
    if (supabaseClient) return supabaseClient;
    const mod = await import('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.47.4/+esm');
    supabaseClient = mod.createClient(supabaseUrl, supabaseAnonKey);
    return supabaseClient;
  }

  const calcForm = document.getElementById('calculator-form');
  const calcError = document.getElementById('calculator-error');
  const calcResult = document.getElementById('calculator-result');
  const leadCard = document.getElementById('lead-form-card');
  const estField = document.getElementById('lead-estimated-price');
  const pagesField = document.getElementById('lead-pages');

  function calculateCost(pages, timeline) {
    let pricePerPage, tier;
    if (pages < 10000) { pricePerPage = 2.0; tier = '<10k'; }
    else if (pages < 50000) { pricePerPage = 1.6; tier = '10k–50k'; }
    else { pricePerPage = 1.2; tier = '50k+'; }

    let days = pages <= 10000 ? 5 : pages <= 50000 ? 10 : 15;
    let label = 'Standard';
    if (timeline === 'expedited') {
      days = Math.max(3, Math.round(days * 0.7));
      label = 'Expedited';
    } else if (timeline === 'flexible') {
      days = Math.round(days * 1.2);
      label = 'Flexible';
    }

    return { estimatedPrice: pages * pricePerPage, days, pricePerPage, tier, label };
  }

  if (calcForm) {
    calcForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(calcForm);
      const pages = Number(formData.get('pages') || 0);
      const documentType = String(formData.get('document_type') || '');
      const timeline = String(formData.get('timeline') || '');
      const location = String(formData.get('location') || '');

      if (calcError) calcError.textContent = '';
      if (!pages || pages < 1) {
        if (calcError) calcError.textContent = 'Please enter a valid number of pages.';
        return;
      }

      const { estimatedPrice, days } = calculateCost(pages, timeline);

      if (calcResult) {
        calcResult.textContent =
          `Estimated Cost: ₹${estimatedPrice.toLocaleString('en-IN', {
            maximumFractionDigits: 0
          })} · Estimated Completion: ${days} days`;
      }

      if (leadCard) {
        leadCard.classList.remove('hidden');
        leadCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      if (estField) estField.value = String(estimatedPrice);
      if (pagesField) pagesField.value = String(pages);
    });
  }

  const leadForm = document.getElementById('lead-form');
  const leadError = document.getElementById('lead-error');
  const leadSuccess = document.getElementById('lead-success');

  if (leadForm) {
    leadForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(leadForm);
      const payload = Object.fromEntries(formData.entries());

      if (leadError) leadError.textContent = '';
      if (leadSuccess) leadSuccess.textContent = '';

      try {
        const client = await getSupabaseClient();
        const { error } = await client.from('leads').insert([{
          name: payload.name,
          company: payload.company,
          email: payload.email,
          phone: payload.phone,
          city: payload.city,
          pages: Number(payload.pages || 0) || 0,
          estimated_price: Number(payload.estimated_price || 0) || 0
        }]);
        if (error) throw error;

        leadForm.reset();
        if (leadSuccess) {
          leadSuccess.textContent =
            'Thank you! Our team will contact you shortly with a detailed quote.';
        }
      } catch (err) {
        if (leadError) {
          leadError.textContent =
            'Unable to submit right now. Please email or call us directly.';
        }
      }
    });
  }
</script>

