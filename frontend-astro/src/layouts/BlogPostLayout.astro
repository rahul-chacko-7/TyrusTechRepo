---
import DefaultLayout from './DefaultLayout.astro';

const { frontmatter, url } = Astro.props;
const pageTitle = frontmatter.seoTitle ?? frontmatter.title;
const pageDescription = frontmatter.seoDescription ?? frontmatter.excerpt ?? '';
const image = frontmatter.image ?? '/og-default.svg';
const siteUrl = (import.meta.env.PUBLIC_SITE_URL || Astro.site?.toString() || 'https://tyrustech.com').replace(/\/$/, '');
const canonicalUrl = new URL(url, siteUrl).toString();
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: frontmatter.title,
  description: pageDescription,
  datePublished: frontmatter.date,
  dateModified: frontmatter.date,
  image: [new URL(image, siteUrl).toString()],
  author: {
    '@type': 'Organization',
    name: 'Tyrus Technologies Pvt Ltd'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Tyrus Technologies Pvt Ltd',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', siteUrl).toString()
    }
  },
  mainEntityOfPage: canonicalUrl
};
---

<DefaultLayout title={pageTitle} description={pageDescription} image={image} type="article">
  <Fragment slot="head">
    <script type="application/ld+json">
      {JSON.stringify(articleSchema)}
    </script>
  </Fragment>
  <section class="bg-slate-950 border-b border-slate-800">
    <div class="mx-auto max-w-5xl px-4 py-14 space-y-8">
      <div class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-300">
          {frontmatter.category ?? 'Insight'}
        </p>
        <h1 class="text-3xl font-semibold text-slate-50">
          {frontmatter.title}
        </h1>
        {frontmatter.excerpt && (
          <p class="max-w-2xl text-sm text-slate-300">
            {frontmatter.excerpt}
          </p>
        )}
        <p class="text-xs text-slate-400">
          {frontmatter.date && new Date(frontmatter.date).toLocaleDateString('en-IN', {
            day: '2-digit',
            month: 'short',
            year: 'numeric'
          })}
        </p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60">
        {frontmatter.image ? (
          <img
            src={frontmatter.image}
            alt={frontmatter.title}
            class="h-56 w-full object-cover sm:h-72"
            loading="lazy"
          />
        ) : (
          <div class="h-40 w-full bg-gradient-to-r from-emerald-500/30 via-sky-500/20 to-slate-900" />
        )}
      </div>
    </div>
  </section>

  <section class="bg-slate-950">
    <div class="mx-auto max-w-3xl px-4 pb-16">
      <article class="prose prose-sm prose-invert prose-emerald max-w-none">
        <slot />
      </article>
    </div>
  </section>
</DefaultLayout>

