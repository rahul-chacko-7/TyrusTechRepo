---
import DefaultLayout from '../layouts/DefaultLayout.astro';

const {
  title,
  description,
  eyebrow,
  h1,
  intro,
  canonical,
  serviceType,
  primaryItems = [],
  process = [],
  industries = [],
  outputs = [],
  faqs = [],
  trustItems = [],
  costFactors = [],
  relatedLinks = []
} = Astro.props;

const faqSchema = faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map(([question, answer]) => ({
        '@type': 'Question',
        name: question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: answer
        }
      }))
    }
  : null;

const pageSchemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: h1,
    serviceType,
    provider: {
      '@type': 'Organization',
      name: 'Tyrus Technologies Pvt Ltd',
      url: 'https://www.tyrustech.com'
    },
    areaServed: {
      '@type': 'Country',
      name: 'India'
    },
    description
  },
  ...(faqSchema ? [faqSchema] : [])
];
---

<DefaultLayout title={title} description={description} canonical={canonical} schemas={pageSchemas}>
  <section class="relative overflow-hidden border-b border-emerald-100 bg-gradient-to-b from-emerald-950 via-emerald-900 to-emerald-800">
    <div class="absolute inset-0">
      <img src="/hero-scanner-bg.png" alt="" class="h-full w-full object-cover opacity-20" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-emerald-950/95 via-emerald-900/85 to-emerald-800/70"></div>
    </div>
    <div class="relative mx-auto grid max-w-6xl gap-8 px-4 py-14 md:grid-cols-[1.15fr,0.85fr] md:items-center md:py-20">
      <div>
        <p class="inline-flex rounded-full border border-emerald-300/40 bg-emerald-800/70 px-3 py-1 text-xs font-semibold text-emerald-100">
          {eyebrow}
        </p>
        <h1 class="mt-5 text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl md:text-5xl">
          {h1}
        </h1>
        <p class="mt-5 max-w-3xl text-sm leading-7 text-emerald-50/90 sm:text-base">
          {intro}
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/#cost-calculator" class="rounded-full bg-emerald-400 px-6 py-2 text-sm font-semibold text-emerald-950 shadow-lg shadow-emerald-950/30 hover:bg-white">
            Get project estimate
          </a>
          <a href="/contact" class="rounded-full border border-emerald-200/70 px-6 py-2 text-sm font-semibold text-emerald-50 hover:bg-emerald-700/70">
            Talk to an expert
          </a>
        </div>
      </div>
      <div class="rounded-3xl border border-emerald-200/30 bg-emerald-950/55 p-5 shadow-2xl shadow-emerald-950/50">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-200">Why this matters</p>
        <ul class="mt-5 space-y-3 text-sm text-emerald-50">
          {primaryItems.map((item) => (
            <li class="rounded-2xl bg-white/10 p-4">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-14 md:grid-cols-[1.05fr,0.95fr]">
      <div>
        <h2 class="text-2xl font-semibold text-slate-900">What Tyrus handles</h2>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-800">
          {primaryItems.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-emerald-500"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-3xl bg-slate-50 p-6 ring-1 ring-slate-200">
        <h2 class="text-xl font-semibold text-slate-900">Typical outputs</h2>
        <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-800">
          {outputs.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-sky-500"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Project workflow</h2>
      <div class="mt-6 grid gap-4 md:grid-cols-4">
        {process.map(([step, text], index) => (
          <article class="rounded-2xl bg-white p-5 ring-1 ring-slate-200">
            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-emerald-600 text-sm font-semibold text-white">{index + 1}</div>
            <h3 class="mt-4 text-sm font-semibold text-slate-900">{step}</h3>
            <p class="mt-2 text-xs leading-6 text-slate-700">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  {(trustItems.length || costFactors.length || relatedLinks.length) && (
    <section class="border-b border-slate-200 bg-white">
      <div class="mx-auto grid max-w-6xl gap-6 px-4 py-14 lg:grid-cols-3">
        {trustItems.length > 0 && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">Security and proof</p>
            <h2 class="mt-2 text-xl font-semibold text-slate-900">Built for confidential records</h2>
            <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-700">
              {trustItems.map((item) => (
                <li class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200">{item}</li>
              ))}
            </ul>
          </div>
        )}

        {costFactors.length > 0 && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">Cost planning</p>
            <h2 class="mt-2 text-xl font-semibold text-slate-900">What affects project pricing</h2>
            <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-700">
              {costFactors.map((item) => (
                <li class="rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200">{item}</li>
              ))}
            </ul>
          </div>
        )}

        {relatedLinks.length > 0 && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-600">Next pages</p>
            <h2 class="mt-2 text-xl font-semibold text-slate-900">Related services and guides</h2>
            <div class="mt-5 space-y-3">
              {relatedLinks.map(([label, href, text]) => (
                <a href={href} class="block rounded-2xl bg-slate-50 p-4 ring-1 ring-slate-200 transition hover:ring-emerald-300">
                  <span class="text-sm font-semibold text-slate-900">{label}</span>
                  <span class="mt-1 block text-xs leading-5 text-slate-600">{text}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )}

  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-semibold text-slate-900">Industries and records covered</h2>
        <p class="mt-3 text-sm leading-7 text-slate-700">
          Tyrus supports India-wide digitization programs for organizations that manage large paper archives, sensitive records, or recurring scanning requirements.
        </p>
      </div>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {industries.map((item) => (
          <div class="rounded-2xl bg-slate-50 p-5 text-sm font-semibold text-slate-900 ring-1 ring-slate-200">{item}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <h2 class="text-2xl font-semibold text-slate-900">Frequently asked questions</h2>
      <div class="mt-6 space-y-4">
        {faqs.map(([question, answer]) => (
          <details class="rounded-2xl bg-white p-5 ring-1 ring-slate-200">
            <summary class="cursor-pointer text-sm font-semibold text-slate-900">{question}</summary>
            <p class="mt-3 text-sm leading-7 text-slate-700">{answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-4 py-14">
      <div class="rounded-3xl bg-gradient-to-r from-emerald-500/10 via-sky-500/10 to-slate-100 p-8 ring-1 ring-emerald-200">
        <h2 class="text-2xl font-semibold text-slate-900">Plan your scanning and digitization project</h2>
        <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-700">
          Share page volume, document type, locations, timeline, and output requirements. Tyrus will suggest the right scanning model, manpower plan, indexing format, and delivery schedule.
        </p>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="/#cost-calculator" class="rounded-full bg-emerald-600 px-6 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700">Calculate estimate</a>
          <a href="/contact" class="rounded-full border border-emerald-300 px-6 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50">Contact Tyrus</a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
