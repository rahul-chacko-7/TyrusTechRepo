---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/industries', label: 'Industries' },
  { href: '/case-studies', label: 'Case Studies' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' }
];
const phone = '+91 80898 89853';
---

<header class="sticky top-0 z-30 border-b border-emerald-100 bg-white/95 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4 py-3">
    <div class="flex items-center justify-between gap-3">
      <a href="/" class="flex items-center gap-3">
        <img
          src="https://tyrustech.com/wp-content/uploads/2021/03/tyruslogo-1024x556.png"
          alt="Tyrus Technologies Pvt Ltd"
          class="h-8 w-auto object-contain"
          loading="lazy"
        />
        <div class="hidden flex-col leading-tight sm:flex">
          <span class="text-sm font-semibold tracking-tight text-slate-900">
            Tyrus Technologies Pvt Ltd
          </span>
          <span class="text-xs text-emerald-700">
            Digitize. Secure. Go Green.
          </span>
        </div>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden items-center gap-6 text-sm text-slate-700 md:flex">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="transition-colors hover:text-emerald-700"
          >
            {item.label}
          </a>
        ))}
        <a
          href="/#cost-calculator"
          class="rounded-full bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-md shadow-emerald-500/40 transition hover:bg-emerald-700"
        >
          Get Cost Estimate
        </a>
        <a
          href={`tel:${phone.replace(/\\s+/g, '')}`}
          class="text-sm font-semibold text-emerald-700"
        >
          {phone}
        </a>
      </nav>

      <!-- Mobile phone + menu button -->
      <div class="flex items-center gap-3 md:hidden">
        <a
          href={`tel:${phone.replace(/\\s+/g, '')}`}
          class="text-xs font-semibold text-emerald-700"
        >
          Call {phone}
        </a>
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-md border border-emerald-200 bg-white p-2 text-slate-800 shadow-sm hover:bg-emerald-50"
          aria-label="Open navigation menu"
          data-mobile-nav-toggle
        >
          <span class="sr-only">Menu</span>
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile dropdown nav -->
    <nav
      class="mt-3 hidden flex-col gap-2 rounded-2xl border border-emerald-100 bg-white p-3 text-sm text-slate-800 shadow-md md:hidden"
      data-mobile-nav
    >
      {navItems.map((item) => (
        <a
          href={item.href}
          class="rounded-lg px-3 py-2 hover:bg-emerald-50 hover:text-emerald-700"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/#cost-calculator"
        class="mt-1 rounded-full bg-emerald-600 px-4 py-2 text-center text-sm font-semibold text-white shadow-md shadow-emerald-500/40 hover:bg-emerald-700"
      >
        Get Cost Estimate
      </a>
    </nav>
  </div>

  <script type="module">
    const toggleButton = document.querySelector('[data-mobile-nav-toggle]');
    const mobileNav = document.querySelector('[data-mobile-nav]');

    if (toggleButton && mobileNav) {
      toggleButton.addEventListener('click', () => {
        mobileNav.classList.toggle('hidden');
      });
    }
  </script>
</header>